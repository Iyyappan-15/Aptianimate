# ─────────────────────────────────────────────────────────────────────
#  AptiAnimate Frontend — Environment Variables Template
#  1. Copy this file:   cp .env.example .env
#  2. Fill in the real values below
#  3. NEVER commit .env to Git — it is blocked by .gitignore
# ─────────────────────────────────────────────────────────────────────

# ── Supabase (Required) ──────────────────────────────────────────────
# Get these from: Supabase Dashboard → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend AI Proxy (Required) ──────────────────────────────────────
# The Express server that securely calls the Gemini/Groq API.
# Development : http://localhost:3000
# Production  : https://your-backend.onrender.com
VITE_API_URL=http://localhost:3000
